# Sonnetary — Environment Variables
# Copy this file to .env.local and fill in real values

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Song pipeline (OpenRouter)
# Server-side key for pipeline LLM calls. Set your OpenRouter account to deny prompt logging/training before going live.
OPENROUTER_API_KEY=sk-or-v1-...
# Optional OpenRouter-compatible base URL override.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Cheap/fast model used for intake interpretation.
YG_MODEL_INTAKE=anthropic/claude-haiku-4.5
# Main model used for creative, lyrics, judging, and rewrite stages.
YG_MODEL_SONNET=anthropic/claude-sonnet-4.6
# Quality judge runs as a multi-model panel (strictest score per dimension wins,
# so weak songs are caught reliably). 'on' (default) or 'off' for a single judge.
YG_JUDGE_PANEL=on
# Optional comma-separated override of the panel models. Default is the main model
# plus two cheap, training-diverse critics. A model that errors is dropped and the
# rest still merge, so a wrong ID degrades gracefully rather than failing the pass.
YG_JUDGE_PANEL_MODELS=anthropic/claude-sonnet-4.6,google/gemini-flash-latest,deepseek/deepseek-chat
# Auto-run policy: paid (default), all, or off.
SONG_PIPELINE_AUTO=paid
# Maximum simultaneous generation jobs.
SONG_PIPELINE_CONCURRENCY=2
# Days before completed generation state is minimized; 0 disables purge.
SONG_PIPELINE_RETENTION_DAYS=90
# Test/dev only: deterministic local pipeline output without LLM calls.
SONG_PIPELINE_MOCK=0
# Test/dev only: number of mock quality passes to force-fail.
SONG_PIPELINE_MOCK_FAILURES=0

# Stripe (legacy — kept for existing orders)
STRIPE_SECRET_KEY=sk_test_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Paystack
PAYSTACK_SECRET_KEY=sk_test_...
VITE_PAYSTACK_PUBLIC_KEY=pk_test_...
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret_here

# Email (Resend)
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@yourdomain.com
# Development only: logs magic-link preview URLs when Resend is not configured.
DEV_MAGIC_LINK_LOG=true

# Admin Dashboard
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_before_production
ADMIN_EMAIL=admin@yourdomain.com
JWT_SECRET=a_long_random_secret_string_here

# Server
SERVER_PORT=3001
CLIENT_URL=http://localhost:3000
NODE_ENV=development
# Comma-separated HTTPS origins that may serve cover images and final audio.
# Example: https://cdn.yourgbedu.com,https://your-bucket.s3.amazonaws.com
MEDIA_CDN_ORIGINS=
# Optional public base URL for production-hosted catalogue audio.
AUDIO_BASE_URL=
# Development note: local API rate-limit state is in memory, so restarting
# the dev server clears local "too many requests" lockouts.

# ── Klaviyo (email flows: welcome, abandoned checkout, order confirmation,
#    song-ready, win-back). We push events; the flows live in the Klaviyo UI. ──
# Server-side Private API key (pk_...). Unset → all Klaviyo calls are no-ops.
KLAVIYO_PRIVATE_KEY=
# List the email-capture popup subscribes to (drives the welcome flow). Optional —
# without it, the welcome flow can be triggered by the "Subscribed to Promo" metric.
KLAVIYO_PROMO_LIST_ID=
# Flip to 1/true ONLY once your Klaviyo confirmation + song-ready flows are live.
# Then Resend stops sending those two (the magic-link email always stays on Resend).
# Leave off until the flows exist, or customers get no confirmation during the gap.
KLAVIYO_OWNS_TRANSACTIONAL=
# Optional API revision pin (defaults to a known-good date in the service).
KLAVIYO_API_REVISION=

# ── Analytics (client-side, consent-gated). Unset → not loaded. ──
# GA4 Measurement ID (G-XXXXXXX).
VITE_GA_MEASUREMENT_ID=
# Meta Pixel ID.
VITE_META_PIXEL_ID=

# Railway (set these in Railway dashboard, not here)
# PORT is injected automatically by Railway — do not set manually
# DB_PATH=/data/sonnetary.db  ← set this if you attach a Railway volume mounted at /data
