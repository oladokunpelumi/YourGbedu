# Sonnetary — Environment Variables
# Copy this file to .env.local and fill in real values

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Stripe (legacy — kept for existing orders)
STRIPE_SECRET_KEY=sk_test_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Paystack
PAYSTACK_SECRET_KEY=sk_test_...
VITE_PAYSTACK_PUBLIC_KEY=pk_test_...
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret_here

# Email (Resend)
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@yourdomain.com
# Development only: logs magic-link preview URLs when Resend is not configured.
DEV_MAGIC_LINK_LOG=true

# Admin Dashboard
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_before_production
ADMIN_EMAIL=admin@yourdomain.com
JWT_SECRET=a_long_random_secret_string_here

# Server
SERVER_PORT=3001
CLIENT_URL=http://localhost:3000
NODE_ENV=development

# Railway (set these in Railway dashboard, not here)
# PORT is injected automatically by Railway — do not set manually
# DB_PATH=/data/sonnetary.db  ← set this if you attach a Railway volume mounted at /data
